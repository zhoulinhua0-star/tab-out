{
  "manifest_version": 3,
  "name": "Tab Out for Edge",
  "version": "1.1.0",
  "description": "Keep tabs on your tabs — Edge edition. New tab page that groups open tabs by domain and closes them with style. Fork of Tab Out for Chromium Edge.",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out for Edge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
